<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.serinity.accesscontrol.controller.sleepcontrol.WeatherController"
  spacing="16.0"
  stylesheets="@../../styles/sleepcontrol/styles.css"
  style="-fx-background-color: #f5f7fa;"
  minWidth="500" minHeight="480">
  <padding>
    <Insets top="24" right="24" bottom="24" left="24" />
  </padding>

  <HBox alignment="CENTER_LEFT" spacing="12.0">
    <Label text="🌤️ Météo &amp; Impact Sommeil" styleClass="page-header" />
    <Region HBox.hgrow="ALWAYS" />
    <Label fx:id="lblStatut" text="" styleClass="stat-card-subtitle" />
    <Button text="🔄 Actualiser" styleClass="btn-secondary"
      onAction="#actualiser" />
  </HBox>

  <VBox fx:id="meteoContainer" spacing="14.0">

    <!-- Météo actuelle -->
    <HBox spacing="12.0">
      <VBox styleClass="stat-card, primary" spacing="4"
        alignment="CENTER" HBox.hgrow="ALWAYS">
        <padding>
          <Insets top="12" right="14" bottom="12" left="14" />
        </padding>
        <Label fx:id="lblEmoji" text="🌡️" style="-fx-font-size:32px;" />
        <Label fx:id="lblTemp" text="–°C" styleClass="stat-card-value" />
        <Label fx:id="lblRessentie" text="–" styleClass="stat-card-subtitle" />
      </VBox>
      <VBox styleClass="stat-card, info" spacing="4"
        alignment="CENTER" HBox.hgrow="ALWAYS">
        <padding>
          <Insets top="12" right="14" bottom="12" left="14" />
        </padding>
        <Label text="📍 VILLE" styleClass="stat-card-title" />
        <Label fx:id="lblVille" text="–" styleClass="stat-card-value-sm" />
        <Label fx:id="lblDescription" text="–" styleClass="stat-card-subtitle" />
      </VBox>
      <VBox styleClass="stat-card, success" spacing="4"
        alignment="CENTER" HBox.hgrow="ALWAYS">
        <padding>
          <Insets top="12" right="14" bottom="12" left="14" />
        </padding>
        <Label text="💧 HUMIDITÉ" styleClass="stat-card-title" />
        <Label fx:id="lblHumidite" text="–" styleClass="stat-card-value-sm" />
        <Label fx:id="lblVent" text="–" styleClass="stat-card-subtitle" />
      </VBox>
    </HBox>

    <!-- Impact sommeil -->
    <VBox styleClass="filter-container" spacing="10.0">
      <padding>
        <Insets top="14" right="16" bottom="14" left="16" />
      </padding>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label text="🛌 Impact sur le Sommeil" styleClass="section-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblAlerte" text="–" styleClass="stat-card-value-sm" />
      </HBox>
      <Label fx:id="lblImpact" text="–" styleClass="card-info"
        wrapText="true" />
    </VBox>

    <!-- Conseil -->
    <VBox styleClass="filter-container" spacing="8.0">
      <padding>
        <Insets top="14" right="16" bottom="14" left="16" />
      </padding>
      <Label text="💡 Conseil du soir" styleClass="section-title" />
      <Label fx:id="lblConseil" text="–" styleClass="tendance-label"
        wrapText="true" />
    </VBox>

  </VBox>
</VBox>
