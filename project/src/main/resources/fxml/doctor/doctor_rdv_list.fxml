<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.serinity.accesscontrol.controller.consultation.doctor.DoctorRdvController"
            styleClass="root"
            stylesheets="@../../styles/app.css">

    <!-- ================= SIDEBAR ================= -->
    <left>
        <VBox spacing="10" styleClass="sidebar">

            <!-- LOGO -->
            <Label text="🏥 MedLink" styleClass="sidebar-logo"/>

            <Separator/>

            <!-- MENU -->
            <Button text="🏠 Dashboard"
                    onAction="#goDashboard"
                    styleClass="side-btn"/>

            <Button text="📅 Rendez-vous Patients"
                    styleClass="side-btn active-side"/>

            <Button text="🧾 Consultations"
                    onAction="#goConsultations"
                    styleClass="side-btn"/>

            <Button text="👨‍⚕️ Mes Patients"
                    onAction="#goPatients"
                    styleClass="side-btn"/>

            <Separator/>



            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⎋ Déconnexion"
                     styleClass="logout-btn"/>

        </VBox>
    </left>

    <!-- ================= CONTENT ================= -->
    <center>
        <VBox spacing="20" styleClass="content">

            <padding>
                <Insets top="22" right="26" bottom="22" left="26"/>
            </padding>

            <!-- ===== HEADER TOOLBAR ===== -->
            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="header-card">

                <Label text="🩺 Gestion des Rendez-vous"
                       styleClass="page-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🔄 Actualiser"
                        onAction="#refresh"
                        styleClass="secondary-btn"/>

            </HBox>

            <!-- ===== LIST ===== -->
            <StackPane VBox.vgrow="ALWAYS">

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color:transparent;">
                    <content>
                        <FlowPane fx:id="cardsPane"
                                  hgap="18"
                                  vgap="18"
                                  prefWrapLength="1050">

                            <padding>
                                <Insets top="10" right="10" bottom="25" left="10"/>
                            </padding>

                        </FlowPane>
                    </content>
                </ScrollPane>

                <!-- EMPTY STATE -->
                <VBox fx:id="emptyBox"
                      alignment="CENTER"
                      spacing="12"
                      visible="false">

                    <Label text="📭 Aucun rendez-vous pour le moment"
                           styleClass="empty-title"/>

                    <Label text="Les demandes des patients apparaîtront ici"
                           styleClass="empty-subtitle"/>

                </VBox>

            </StackPane>

        </VBox>
    </center>

</BorderPane>