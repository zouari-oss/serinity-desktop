<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.serinity.exercicecontrol.controller.CoachDashboardController"
            styleClass="coach-root"
            stylesheets="@../../styles/coachstyle.css">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="coach-topbar">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>

            <Label text="Coach IA" styleClass="coach-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Exercice" styleClass="coach-label"/>
            <ComboBox fx:id="cbExercise" prefWidth="320" styleClass="coach-input"/>

            <Label text="Fenêtre (jours)" styleClass="coach-label"/>
            <Spinner fx:id="daysSpinner" prefWidth="120" styleClass="coach-input"/>

            <Button fx:id="btnAnalyze" text="Analyser" onAction="#onAnalyze" styleClass="btn-primary"/>
            <Button fx:id="btnCoach" text="Demander au coach" onAction="#onCoach" styleClass="btn-secondary"/>
            <Button text="Retour" onAction="#onClose" styleClass="btn-ghost"/>
        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <SplitPane dividerPositions="0.45" styleClass="coach-split">

            <!-- LEFT PANE -->
            <VBox spacing="12" styleClass="coach-pane">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <VBox spacing="10" styleClass="coach-card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Rapport de performance" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="loading" visible="false" prefWidth="18" prefHeight="18"/>
                    </HBox>

                    <FlowPane hgap="10" vgap="10">
                        <VBox styleClass="kpi">
                            <Label text="Statut" styleClass="kpi-title"/>
                            <Label fx:id="lblStatus" text="—" styleClass="kpi-value"/>
                        </VBox>

                        <VBox styleClass="kpi">
                            <Label text="Tendance" styleClass="kpi-title"/>
                            <Label fx:id="lblTrend" text="—" styleClass="kpi-value"/>
                        </VBox>

                        <VBox styleClass="kpi">
                            <Label text="Sessions" styleClass="kpi-title"/>
                            <Label fx:id="lblSessions" text="—" styleClass="kpi-value"/>
                        </VBox>

                        <VBox styleClass="kpi">
                            <Label text="Durée moyenne" styleClass="kpi-title"/>
                            <Label fx:id="lblAvg" text="—" styleClass="kpi-value"/>
                        </VBox>

                        <VBox styleClass="kpi">
                            <Label text="Flags" styleClass="kpi-title"/>
                            <Label fx:id="lblFlags" text="—" styleClass="kpi-value"/>
                        </VBox>
                    </FlowPane>
                </VBox>

                <VBox spacing="10" styleClass="coach-card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Recommandations" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="local" styleClass="pill-muted"/>
                    </HBox>

                    <ListView fx:id="lvRecs" styleClass="coach-list" VBox.vgrow="ALWAYS"/>
                </VBox>

                <VBox spacing="10" styleClass="coach-card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Prochaine séance" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="objectif" styleClass="pill-muted"/>
                    </HBox>

                    <Label fx:id="lblNextPlan" text="—" styleClass="body-muted" wrapText="true"/>
                </VBox>

            </VBox>

            <!-- RIGHT PANE -->
            <VBox spacing="12" styleClass="coach-pane">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <VBox spacing="10" styleClass="coach-card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Coach (IA)" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Gemini" styleClass="pill-accent"/>
                    </HBox>

                    <Label text="Résumé" styleClass="section-label"/>
                    <Label fx:id="lblCoachSummary" text="—" styleClass="body-text" wrapText="true"/>
                </VBox>

                <VBox spacing="10" styleClass="coach-card">
                    <Label text="Actions" styleClass="section-label"/>
                    <VBox fx:id="actionsBox" spacing="8"/>
                </VBox>

                <VBox spacing="10" styleClass="coach-card" VBox.vgrow="ALWAYS">
                    <Label text="Séance détaillée" styleClass="section-label"/>
                    <TextArea fx:id="taCoachNextSession"
                              wrapText="true"
                              editable="false"
                              styleClass="coach-textarea"
                              VBox.vgrow="ALWAYS"/>
                </VBox>

                <VBox spacing="6">
                    <Label fx:id="lblCoachSafety" text="" styleClass="body-muted" wrapText="true"/>
                    <Label fx:id="lblStatusBar" text="Prêt." styleClass="footer-status"/>
                </VBox>

            </VBox>

        </SplitPane>
    </center>

</BorderPane>