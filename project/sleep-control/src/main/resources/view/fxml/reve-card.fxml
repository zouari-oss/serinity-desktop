<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.serinity.sleepcontrol.controller.ReveCardController"
      fx:id="cardRoot"
      styleClass="card"
      stylesheets="@../styles/styles.css"
      maxWidth="280.0"
      prefWidth="280.0"
      spacing="0.0">

    <!-- ── Barre dégradé teal→cyan en haut ── -->
    <HBox styleClass="card-accent-bar" maxWidth="1.7976931348623157E308" />

    <!-- ── Contenu principal ── -->
    <VBox styleClass="card-body" spacing="7.0">

        <!-- En-tête : titre + badge type -->
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10.0">
            <Label fx:id="titreLabel" styleClass="card-date" wrapText="true"
                   HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
            <Label fx:id="typeLabel" styleClass="type-label" />
        </HBox>

        <!-- Description -->
        <Label fx:id="descriptionLabel" styleClass="card-info"
               wrapText="true" maxWidth="240.0" />

        <!-- Humeur -->
        <Label fx:id="humeurLabel" styleClass="card-info" />

        <!-- Intensité -->
        <HBox alignment="CENTER_LEFT" spacing="6.0">
            <Label styleClass="card-info" text="⚡ Intensité:" />
            <ProgressBar fx:id="intensiteBar" prefWidth="90.0" prefHeight="8.0" />
            <Label fx:id="intensiteValue" styleClass="card-info-secondary" />
        </HBox>

        <!-- Anxiété -->
        <Label fx:id="anxieteLabel" styleClass="card-info" />

        <!-- Badges couleur / récurrent / lucide -->
        <HBox alignment="CENTER_LEFT" spacing="6.0">
            <Label fx:id="couleurBadge"
                   styleClass="badge,badge-couleur"
                   visible="false" managed="false" />
            <Label fx:id="recurrentBadge"
                   styleClass="badge,badge-recurrent"
                   visible="false" managed="false" />
            <Label fx:id="lucideBadge"
                   styleClass="badge,badge-lucide"
                   visible="false" managed="false" />
        </HBox>

        <!-- Émotions (optionnel) -->
        <Label fx:id="emotionsLabel"
               styleClass="card-dreams"
               managed="false" visible="false"
               wrapText="true" maxWidth="240.0" />

        <!-- ── Footer boutons ── -->
        <HBox styleClass="card-footer" alignment="CENTER_LEFT" spacing="6.0">
            <padding>
                <Insets top="6.0" />
            </padding>

            <!-- Voir : teal plein, texte court -->
            <Button fx:id="btnVoir"
                    text="Voir"
                    styleClass="btn-card-voir,btn-sm"
                    prefWidth="58.0" />

            <!-- IA : secondaire -->
            <Button fx:id="btnAnalyse"
                    text="IA"
                    styleClass="btn-secondary,btn-sm"
                    prefWidth="40.0" />

            <!-- Modifier : ambre, texte court -->
            <Button fx:id="btnModifier"
                    text="Modifier"
                    styleClass="btn-card-modifier,btn-sm"
                    prefWidth="72.0" />

            <!-- Supprimer : icône seule -->
            <Button fx:id="btnSupprimer"
                    text="✕"
                    styleClass="btn-card-delete,btn-sm"
                    prefWidth="32.0" />
        </HBox>


    </VBox>

</VBox>
