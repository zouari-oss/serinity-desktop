<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" stylesheets="@/view/styles/styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.serinity.sleepcontrol.controller.AdminDashboardController">

    <styleClass>
        <String fx:value="app-bg" />
    </styleClass>

    <VBox maxWidth="920" prefWidth="920" spacing="16">
        <padding>
            <Insets bottom="24" left="24" right="24" top="24" />
        </padding>

        <styleClass>
            <String fx:value="admin-card" />
        </styleClass>

        <Label text="Backoffice Admin — Statistiques">
            <styleClass>
                <String fx:value="admin-title" />
            </styleClass>
        </Label>

        <Label wrapText="true">
            <styleClass>
                <String fx:value="admin-subtitle" />
            </styleClass>
        </Label>

        <HBox spacing="12">
            <Button onAction="#gererSommeil" text="🛠 Gérer statistiques Sommeil">
                <styleClass>
                    <String fx:value="admin-btn" />
                    <String fx:value="admin-btn-info" />
                </styleClass>
            </Button>

            <Button onAction="#gererReve" text="🛠 Gérer statistiques Rêve">
                <styleClass>
                    <String fx:value="admin-btn" />
                    <String fx:value="admin-btn-primary" />
                </styleClass>
            </Button>

            <Button onAction="#retour" text="⬅ Retour">
                <styleClass>
                    <String fx:value="admin-btn" />
                    <String fx:value="admin-btn-teal" />
                </styleClass>
            </Button>
        </HBox>
    </VBox>

</StackPane>
