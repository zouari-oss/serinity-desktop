<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
  style="-fx-background-color: #f5f7fa;"
  xmlns="http://javafx.com/javafx/17.0.12"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.serinity.accesscontrol.controller.sleepcontrol.HumeurReveilController">

  <padding>
    <Insets bottom="25" left="25" right="25" top="25" />
  </padding>

  <!-- Header -->
  <HBox alignment="CENTER_LEFT" spacing="10">
    <Label text="😴 Analyse Humeur du Réveil"
      style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #3F51B5;" />
    <Region HBox.hgrow="ALWAYS" />
    <Label text="HuggingFace NLP"
      style="-fx-font-size: 11px; -fx-text-fill: #aaa;" />
  </HBox>

  <Separator />

  <!-- Sélection rêve -->
  <VBox spacing="10"
    style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-padding: 18;
                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">

    <Label text="🌙 Quel rêve as-tu fait cette nuit ?"
      style="-fx-font-size: 14px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #333;" />

    <ComboBox fx:id="comboReve"
      maxWidth="Infinity"
      promptText="— Sélectionne un rêve —"
      style="-fx-font-size: 13px;" />

    <Button fx:id="btnAnalyser"
      onAction="#analyser"
      text="🔍 Analyser mon humeur"
      maxWidth="Infinity"
      style="-fx-background-color: #3F51B5;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-padding: 10;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;" />
  </VBox>

  <!-- Sentiment -->
  <VBox fx:id="sentimentBox"
    visible="false"
    managed="false"
    spacing="12"
    style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-padding: 18;
                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">

    <Label text="💬 Humeur détectée au réveil"
      style="-fx-font-size: 14px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #333;" />

    <HBox alignment="CENTER" spacing="25">
      <Label fx:id="lblEmoji"
        text="😐"
        style="-fx-font-size: 52px;" />
      <VBox spacing="6" alignment="CENTER_LEFT">
        <Label fx:id="lblSentiment" text="—"
          style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <ProgressBar fx:id="progressBar"
          progress="0"
          prefWidth="370"
          prefHeight="10" />
        <Label fx:id="lblConfiance" text=""
          style="-fx-text-fill: #999; -fx-font-size: 12px;" />
      </VBox>
    </HBox>
  </VBox>

  <!-- Recommandations -->
  <VBox fx:id="recoBox"
    visible="false"
    managed="false"
    spacing="10"
    VBox.vgrow="ALWAYS"
    style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-padding: 18;
                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">

    <Label text="✨ Recommandations pour ta journée"
      style="-fx-font-size: 14px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #3F51B5;" />

    <TextArea fx:id="txtRecommandations"
      editable="false"
      wrapText="true"
      VBox.vgrow="ALWAYS"
      prefHeight="150"
      style="-fx-font-size: 13px;
                         -fx-background-color: #f0f4ff;
                         -fx-border-color: #c5cae9;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;" />
  </VBox>

</VBox>
