<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.serinity.accesscontrol.controller.exercice.PlanDuJourController"
            fitToWidth="true"
            stylesheets="@../../../styles/exercice/styles.css"
            styleClass="transparent-scroll">

    <content>
        <VBox spacing="16" styleClass="page-root">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="session-header">
                <Button text="← Retour" onAction="#onBack" styleClass="secondary-btn"/>
                <VBox spacing="2">
                    <Label text="Plan du jour" styleClass="session-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Rafraîchir" onAction="#onRefreshPlan" styleClass="secondary-btn"/>
            </HBox>

            <!-- SUMMARY CARDS -->
            <HBox spacing="14">
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Contexte" styleClass="muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblWeatherBadge" text="—" />
                    </HBox>
                    <Label fx:id="lblContext" text="—" styleClass="metric-value"/>
                </VBox>

                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Météo" styleClass="muted"/>
                    <Label fx:id="lblWeather" text="—" styleClass="metric-value"/>
                </VBox>

                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Fatigue estimée" styleClass="muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblFatigueBadge" text="—" />
                    </HBox>
                    <Label fx:id="lblWearable" text="—" styleClass="metric-value"/>
                </VBox>
            </HBox>

            <!-- FATIGUE INPUT -->
            <VBox spacing="10" styleClass="card" fx:id="boxFatigueFallback">
                <Label text="Ajuster la fatigue du jour" styleClass="section-title"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Fatigue :" styleClass="muted"/>
                    <Slider fx:id="sliderFatigue" min="0" max="100" value="50" prefWidth="280"/>
                    <Label fx:id="lblFatigueValue" text="50/100" styleClass="muted"/>
                </HBox>
            </VBox>

            <!-- PLAN -->
            <GridPane hgap="14" vgap="14">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="10" styleClass="card" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Activité physique proposée" styleClass="section-title"/>
                    <Label fx:id="lblActivity" text="—" wrapText="true" styleClass="body-text"/>
                </VBox>

                <VBox spacing="10" styleClass="card" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Méditation proposée" styleClass="section-title"/>
                    <Label fx:id="lblMeditation" text="—" wrapText="true" styleClass="body-text"/>
                </VBox>

                <VBox spacing="10" styleClass="card" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2">
                    <Label text="Pourquoi ce plan ?" styleClass="section-title"/>
                    <Label fx:id="lblWhy" text="—" wrapText="true" styleClass="body-text"/>
                </VBox>
            </GridPane>

            <!-- YOUTUBE -->
            <VBox spacing="10" styleClass="card">
                <Label text="Vidéos recommandées (YouTube)" styleClass="section-title"/>
                <Label fx:id="lblYouTubeStatus" text="—" styleClass="muted" wrapText="true"/>
                <ListView fx:id="listYouTube" prefHeight="220"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>